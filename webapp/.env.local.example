# Copy this file to .env.local (git-ignored) and fill in the real values
# from `supabase status` after `supabase start`.

# Supabase local stack (defaults from `supabase start`; service role key
# is unique per machine — copy from `supabase status`)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=replace-me-with-output-of-supabase-status

# vdetect FastAPI (started via `python -m vdetect`)
VDETECT_BASE_URL=http://127.0.0.1:8000

# Public site origin — overridden at deploy time with the Tailscale Funnel URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
